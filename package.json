{
  "name": "rss-the-planet",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "node ./src/_node-boot.js",
    "start:wrangler": "wrangler dev --ip 0.0.0.0",
    "test": "npm run lint && npm run test:medium",
    "test:wrangler": "npm run lint && npm run test:medium:wrangler",
    "test:fast": "vitest run --pool=forks --exclude **/proxy-test-end2end-w3c-validation.test.js",
    "test:fast:wrangler": "vitest run --exclude **/proxy-test-end2end-w3c-validation.test.js",
    "test:medium": "npm run test:fast && npm run test:e2e:fast",
    "test:medium:wrangler": "npm run test:fast:wrangler && npm run test:e2e:fast:wrangler",
    "test:slow": "npm run test:fast && npm run test:e2e:full",
    "test:slow:wrangler": "npm run test:fast:wrangler && npm run test:e2e:full:wrangler",
    "test:e2e:fast": "rm -f tests/.run-full-suite && TEST_TARGET=node vitest run tests/proxy-test-end2end-w3c-validation.test.js --pool=forks",
    "test:e2e:fast:wrangler": "rm -f tests/.run-full-suite && TEST_TARGET=wrangler vitest run tests/proxy-test-end2end-w3c-validation.test.js --pool=forks",
    "test:e2e:full": "touch tests/.run-full-suite && TEST_TARGET=node vitest run tests/proxy-test-end2end-w3c-validation.test.js --pool=forks",
    "test:e2e:full:wrangler": "touch tests/.run-full-suite && TEST_TARGET=wrangler vitest run tests/proxy-test-end2end-w3c-validation.test.js --pool=forks",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check": "npm run lint && prettier --check .",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@miniflare/html-rewriter": "^2.14.4",
    "dotenv": "^17.2.3",
    "fast-xml-parser": "^5.3.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.12.12",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-sonarjs": "^4.0.0",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "vitest": "^3.2.4"
  }
}
